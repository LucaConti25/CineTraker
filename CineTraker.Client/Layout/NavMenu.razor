@inject IJSRuntime JS

<div class="menu-pill-container @(collapseNavMenu ? "closed" : "open")"
     @onmouseover="ExpandMenu"
     @onmouseout="CollapseMenu">

    <div class="menu-options">
        <NavLink class="nav-btn circular-btn" href="login" title="Login">
            <i class="bi bi-person-badge-fill"></i>
        </NavLink>

        <NavLink class="nav-btn circular-btn" href="" Match="NavLinkMatch.All" title="Inicio">
            <i class="bi bi-house-door-fill"></i>
        </NavLink>
    </div>

    <button class="main-trigger" @onclick="ToggleNavMenu">
        <i class="bi bi-list"></i>
    </button>

</div>

@code {
    private bool collapseNavMenu = true;
    private void ToggleNavMenu() => collapseNavMenu = !collapseNavMenu;
    private void ExpandMenu() => collapseNavMenu = false;
    private void CollapseMenu() => collapseNavMenu = true;
}