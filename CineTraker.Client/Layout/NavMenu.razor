<div class="sidebar-container @NavMenuCssClass">
    <div class="top-row ps-3 navbar navbar-dark">
        <div class="container-fluid">
            @if (!collapseNavMenu)
            {
                    <a class="navbar-brand" href="">CineTraker</a>
            }
            <button title="Navigation menu" class="navbar-toggler" @onclick="ToggleNavMenu">
                <span class="navbar-toggler-icon"></span>
            </button>
        </div>
    </div>

    <div class="nav-scrollable">
        <nav class="flex-column">
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                    <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span>
                    @if (!collapseNavMenu)
                    {
                            <span class="nav-text ms-2">Inicio</span>
                    }
                </NavLink>
            </div>
        </nav>
    </div>
</div>

@code {
    private bool collapseNavMenu = false;

    // Esta clase se aplica al contenedor principal del componente
    private string NavMenuCssClass => collapseNavMenu ? "menu-collapsed" : "menu-expanded";

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }
}