@inject IJSRuntime JS

<div class="sidebar-container @(!collapseNavMenu ? "menu-open" : "")"
        style="position:fixed; top:0; left:0; height:100vh; width:220px; z-index:1000; background-color:#1a1a1a; transform:@(collapseNavMenu ? "translateX(-170px)" : "translateX(0)"); transition:transform 0.3s ease; overflow:hidden; display:flex; flex-direction:column;"
        @onmouseover="ExpandMenu"
        @onmouseout="CollapseMenu">

    <div class="nav-scrollable" style="padding-top: 1rem;">
        <nav class="flex-column">
            <div class="nav-item px-3" @onclick="ToggleNavMenu" @onclick:stopPropagation="true">
                <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                    <i class="bi bi-house-door-fill nav-icon"></i>
                    <span class="nav-text ms-2">Inicio</span>
                </NavLink>
            </div>
            <div class="nav-item px-3" @onclick="ToggleNavMenu" @onclick:stopPropagation="true">
                <NavLink class="nav-link" href="login">
                    <i class="bi bi-person-badge-fill nav-icon"></i>
                    <span class="nav-text ms-2">Login</span>
                </NavLink>
            </div>
        </nav>
    </div>
</div>

@code {
    private bool collapseNavMenu = true;
    private void ToggleNavMenu() => collapseNavMenu = !collapseNavMenu;
    private void ExpandMenu() => collapseNavMenu = false;
    private void CollapseMenu() => collapseNavMenu = true;
}


