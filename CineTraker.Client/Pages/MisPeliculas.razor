@page "/"
@using CineTraker.Shared
@using CineTraker.Shared.Models
@using Microsoft.AspNetCore.Components.Authorization
@inject HttpClient Http
@inject IJSRuntime JS
<PageTitle>CineTraker - Inicio</PageTitle>

<div class="container-fluid pt-2 pt-md-4 px-3 px-md-5">

    @* --- BÚSQUEDA LOCAL E INTELIGENTE --- *@
    <div class="search-box mt-0 mb-3 p-3 p-md-4 rounded shadow" style="background-color: #1e1e1e; border: 1px solid #333;">
        <h4 class="text-light mb-3">🔍 Buscar en mi catálogo</h4>
        <div class="input-group">
            <input type="text" class="form-control bg-dark text-light border-secondary" 
                   placeholder="Escribí el nombre de una película que ya esté cargada..." 
                   @bind="textoBusqueda" @bind:event="oninput" />
        </div>

        @if (peliculas != null && !PeliculasFiltradas.Any() && !string.IsNullOrEmpty(textoBusqueda))
{
            <AuthorizeView>
                <Authorized>
                    <button class="btn btn-danger" @onclick="EjecutarBusquedaInteligente" disabled="@buscandoEnApi">
                        @if (buscandoEnApi)
                        {
                            <span class="spinner-border spinner-border-sm"></span>
                        }
                        else
                        {
                            <span>¿Buscar en internet?</span>
                        }
                    </button>
                </Authorized>
                <NotAuthorized>
                    <a href="login" class="btn btn-outline-secondary btn-sm">
                        Iniciá sesión para buscar en internet
                    </a>
                </NotAuthorized>
            </AuthorizeView>
}
    </div>
    
    @*BARRA DE FILTROS (DROPDOWNS HORIZONTALES) *@
    <div class="d-flex flex-wrap align-items-center gap-2 mb-5">

        @* Dropdown de Década *@
        <div class="dropdown">
            <button class="pill-dropdown @(filtrosDecadas.Any(f => f.Seleccionado) ? "active" : "")" 
                    type="button" @onclick="ToggleDropdown" @onfocusout="CerrarDropdown">

                        @{
                            var seleccionada = filtrosDecadas.FirstOrDefault(f => f.Seleccionado);
                            if (seleccionada != null)
                            {
                                <span class="fw-bold">@seleccionada.Etiqueta</span>
                            }
                            else
                            {
                                <span>DÉCADA</span>
                                <span class="ms-2 text-muted">---</span>
                            }
                        }
                <i class="bi bi-chevron-down ms-2 small"></i>
            </button>

            <ul class="dropdown-menu dropdown-menu-dark custom-dropdown-menu @(mostrarDropdown ? "show" : "")">
                        @foreach (var decada in filtrosDecadas)
                        {
                        <li>
                            <button class="dropdown-item @(decada.Seleccionado ? "active-item" : "")" 
                                    @onmousedown="() => SeleccionarDecada(decada)">
                                    @decada.Etiqueta
                            </button>
                        </li>
                        }
            </ul>
        </div>

        @* --- Dropdown de GÉNERO --- *@
        <div class="dropdown">
            <button class="pill-dropdown @(!string.IsNullOrEmpty(generoSeleccionado) ? "active" : "")"
                    type="button" @onclick="ToggleGenero" @onfocusout="CerrarGenero">
                @if (!string.IsNullOrEmpty(generoSeleccionado))
                {
                    <span class="fw-bold">@generoSeleccionado.ToUpper()</span>
                }
                else
                {

                    <span>GÉNERO</span>
                    <span class="ms-2 text-muted">---</span>
                }
                <i class="bi bi-chevron-down ms-2 small"></i>
            </button>
            <ul class="dropdown-menu dropdown-menu-dark custom-dropdown-menu @(mostrarGenero ? "show" : "")">
                <li><button class="dropdown-item" @onmousedown='() => SeleccionarGenero(null)'>TODOS</button></li>
                @foreach (var g in generos)
                {
                    <li><button class="dropdown-item @(generoSeleccionado == g ? "active-item" : "")" @onmousedown="() => SeleccionarGenero(g)">@g.ToUpper()</button></li>
                }
            </ul>
        </div>

        @* --- Dropdown de PUNTUACIÓN --- *@
        <div class="dropdown">
            <button class="pill-dropdown @(ratingSeleccionado.HasValue ? "active" : "")"
                    type="button" @onclick="ToggleRating" @onfocusout="CerrarRating">
                @if (ratingSeleccionado.HasValue)
                {
                    <span class="fw-bold">⭐ +@ratingSeleccionado.Value.ToString("0.0")</span>
                }
                else
                {

                    <span>PUNTUACIÓN IMDB</span>
                    <span class="ms-2 text-muted">---</span>
                }
                <i class="bi bi-chevron-down ms-2 small"></i>
            </button>
            <ul class="dropdown-menu dropdown-menu-dark custom-dropdown-menu @(mostrarRating ? "show" : "")">
                <li><button class="dropdown-item" @onmousedown='() => SeleccionarRating(null)'>CUALQUIERA</button></li>
                <li><button class="dropdown-item" @onmousedown="() => SeleccionarRating(6.0)">⭐ +6.0</button></li>
                <li><button class="dropdown-item" @onmousedown="() => SeleccionarRating(7.0)">⭐ +7.0</button></li>
                <li><button class="dropdown-item" @onmousedown="() => SeleccionarRating(8.0)">🌟 +8.0</button></li>
                <li><button class="dropdown-item" @onmousedown="() => SeleccionarRating(9.0)">🔥 TOP (+9.0)</button></li>
            </ul>
        </div>

        @* --- Filtro de PLATAFORMA --- *@
        <div class="dropdown">
            <button class="pill-dropdown @(!string.IsNullOrEmpty(plataformaSeleccionada) ? "active" : "")"
                    type="button" @onclick="TogglePlataforma" @onfocusout="CerrarPlataforma">

                        @if (!string.IsNullOrEmpty(plataformaSeleccionada))
                        {
                        <span class="fw-bold">@plataformaSeleccionada.ToUpper()</span>
                        }
                        else
                        {
                        <span>PLATAFORMA</span>
                        <span class="ms-2 text-muted">---</span>
                        }
                <i class="bi bi-chevron-down ms-2 small"></i>
            </button>

            <ul class="dropdown-menu dropdown-menu-dark custom-dropdown-menu @(mostrarPlataforma ? "show" : "")">
                <li><button class="dropdown-item" @onmousedown='() => SeleccionarPlataforma(null)'>CUALQUIERA</button></li>
                        @foreach (var plat in plataformasFrecuentes)
                        {
                        <li>
                            <button class="dropdown-item @(plataformaSeleccionada == plat ? "active-item" : "")" 
                                    @onmousedown="() => SeleccionarPlataforma(plat)">
                                    @plat.ToUpper()
                            </button>
                        </li>
                        }
            </ul>
        </div>
        @* Acá irían las otras píldoras (GÉNERO, DIRECTOR, etc.) siguiendo la misma estructura *@
    </div>



    @* CARTELERA DE PELÍCULAS *@
    <h2 class="fw-bold mb-4 text-light">Cartelera</h2>

    @if (peliculas.Count == 0 && !finDelCatalogo)
    {
            <div class="text-center mt-5">
                <div class="spinner-border text-danger" role="status"></div>
                <p class="text-muted mt-2">Cargando catálogo...</p>
            </div>
    }
    else
    {
        <div class="row row-cols-2 row-cols-sm-3 row-cols-md-4 row-cols-lg-5 row-cols-xl-6 g-3 g-md-4">
            @foreach (var peli in PeliculasFiltradas)
            {
                <div class="col">
                    @* El href construye una ruta dinámica usando el Id de la base de datos *@
                    <NavLink href="@($"/pelicula/{peli.Id}")" style="text-decoration: none;">
                        <div class="card h-100 border-0 bg-transparent movie-card">
                            <div class="poster-container shadow">
                                <img src="@peli.SafePosterUrl" class="card-img-top rounded" onerror="this.src='https://placehold.co/300x450?text=Sin+Poster'" alt="@peli.Title">
                                @if (!string.IsNullOrEmpty(peli.ImdbRating) && peli.ImdbRating != "N/A")
                                {
                                    <div class="imdb-rating-badge">
                                        ⭐ @peli.ImdbRating
                                    </div>
                                }
                            </div>
                            <div class="card-body px-0 pt-2 text-center">
                                <h6 class="text-truncate mb-0 fw-bold text-light">@peli.Title</h6>
                                <span class="text-muted small">@peli.Year</span>
                            </div>
                        </div>
                    </NavLink>
                </div>
            }

        </div>

        @if (cargandoMas)
        {
            <div class="text-center my-4 w-100">
                <div class="spinner-border text-warning" role="status"></div>
                <p class="text-muted">Buscando más joyas...</p>
            </div>
        }
    }
</div>



@* MODALES Y NOTIFICACIONES *@
@if (mostrarModalExterno)
{
        <div class="custom-modal-overlay">
            <div class="custom-modal-content">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="text-warning m-0">¿Cuál de estas buscabas?</h5>
                    <button class="btn-close btn-close-white" @onclick="() => mostrarModalExterno = false"></button>
                </div>

                <div class="modal-results-body">
                @if (buscandoEnApi)
                {
                            <div class="text-center py-4">
                                <div class="spinner-border text-warning"></div>
                                <p class="text-muted mt-2">Consultando a internet...</p>
                            </div>
                }
                else
                {
                            <div class="row row-cols-2 row-cols-md-3 g-3">
                        @foreach (var res in resultadosExternos)
                        {
                                        <div class="col">
                                            <div class="card h-100 bg-dark border-secondary option-card" @onclick="() => ConfirmarYGuardar(res)">
                                                <img src="@res.SafePosterUrl" class="card-img-top">
                                                <div class="card-body p-2">
                                                    <p class="small fw-bold mb-0 text-truncate">@res.Title</p>
                                                    <span class="text-muted small">@res.Year</span>
                                                </div>
                                            </div>
                                        </div>
                        }
                            </div>
                }
                </div>
            </div>
        </div>
}



@if (mostrarFeedback)
{
        <div class="feedback-toast shadow-lg border-0 animacion-entrada">
            <div class="d-flex align-items-center p-3 text-white bg-success rounded">
                <i class="bi bi-check-circle-fill me-2 fs-4"></i>
                <div>
                    <strong class="d-block">¡Agregada con éxito!</strong>
                    <span class="small">"@peliculaAgregada" ya está en tu catálogo.</span>
                </div>
            </div>
        </div>
}




