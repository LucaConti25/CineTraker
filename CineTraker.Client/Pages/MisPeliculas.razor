@page "/mis-peliculas"
@using CineTraker.Shared
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@inject HttpClient Http
@inject NavigationManager Nav

<div class="main-content-container pb-5">
    @* --- CONTENEDOR PRINCIPAL CON COHERENCIA DE COLOR --- *@
    @if (userReviews == null)
        {
            <div class="container pt-4">
                <div class="text-center text-white mt-5">
                    <div class="spinner-border text-warning" role="status"></div>
                    <p class="mt-2">Cargando tu diario...</p>
                </div>
            </div>
        }
        else if (!userReviews.Any())
        {
            <div class="container mt-4">
                <div class="alert alert-info bg-dark text-info border-info">
                    Todavía no has calificado ninguna película.
                </div>
            </div>
        }
        else
        {
            <div class="container pt-4">
                <h2 class="text-white mb-4">
                    <i class="bi bi-journal-bookmark-fill text-warning me-2"></i>Mi Diario de Películas
                </h2>

                @* --- VISTA MOBILE: CARDS (Coherente con comment-card de Detalles) --- *@
                <div class="d-block d-md-none">
                    @foreach (var review in userReviews)
                    {
                            <div class="card bg-dark border-secondary mb-3 shadow-sm comment-card">
                                <div class="card-body">
                                    <div class="d-flex justify-content-between align-items-start mb-2">
                                        <div class="d-flex align-items-center mb-3">
                                            <img src="@review.Movie?.PosterUrl" 
                                                 class="rounded me-3 border border-secondary" 
                                                 style="width: 45px; height: 65px; object-fit: cover;" />
                                            <div>
                                                <h5 class="text-white fw-bold mb-0">@review.Movie?.Title</h5>
                                                <span class="text-muted small">@review.Movie?.Year</span>
                                            </div>
                                        </div>
                                        <span class="text-muted small">@review.CreatedAt.ToString("dd MMM yyyy")</span>
                                    </div>

                                    <div class="text-warning mb-3">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                                <i class="bi @(i <= review.Stars ? "bi-star-fill" : "bi-star text-secondary")"></i>
                                    }
                                    </div>

                                    <p class="text-light small mb-3 border-start border-warning ps-2" style="white-space: pre-wrap;">
                                    @(review.Comment ?? "Sin comentarios")
                                    </p>

                                    <div class="d-flex justify-content-end gap-2 pt-2 border-top border-secondary">
                                        <button class="btn btn-outline-info btn-sm rounded-pill px-3" @onclick="() => AbrirModalEdicion(review)">
                                            <i class="bi bi-pencil-square"></i>
                                        </button>
                                        <button class="btn btn-outline-danger btn-sm rounded-pill px-3" @onclick="() => EliminarReview(review.Id)">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                </div>
                            </div>
                    }
                </div>

                @* --- VISTA DESKTOP: TABLA REFINADA --- *@
                <div class="d-none d-md-block">
                    <div class="card bg-dark border-secondary shadow-sm overflow-hidden" style="border-radius: 15px;">
                        <div class="table-responsive">
                            <table class="table table-dark table-hover align-middle mb-0">
                                <thead class="bg-black">
                                    <tr class="text-muted small text-uppercase border-secondary">
                                        <th class="ps-4 py-3">Película</th>
                                        <th>Fecha</th>
                                        <th>Calificación</th>
                                        <th>Comentario</th>
                                        <th class="text-end pe-4">Acciones</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var review in userReviews)
                                    {
                                        <tr class="border-secondary">
                                            <td class="ps-4">
                                                <div class="d-flex align-items-center">
                                                                                    @* Miniatura del Póster *@
                                                    <img src="@review.Movie?.PosterUrl" 
                                                         class="rounded me-3 shadow-sm border border-secondary" 
                                                         style="width: 35px; height: 50px; object-fit: cover;" 
                                                         alt="Poster" />

                                                    <div>
                                                        <strong class="text-white fs-6 d-block">@review.Movie?.Title</strong>
                                                        <span class="text-muted small">@review.Movie?.Year</span>
                                                    </div>
                                                </div>
                                            </td>
                                            <td class="text-muted small">@review.CreatedAt.ToString("dd MMM yyyy")</td>
                                            <td>
                                                <div class="text-warning">
                                                    @for (int i = 1; i <= 5; i++)
                                                    {
                                                            <i class="bi @(i <= review.Stars ? "bi-star-fill" : "bi-star text-secondary")"></i>
                                                    }
                                                </div>
                                            </td>
                                            <td>
                                                <span class="text-light-50 small text-truncate d-block" style="max-width: 250px;">
                                                    @(review.Comment ?? "Sin comentarios")
                                                </span>
                                            </td>
                                            <td class="text-end pe-4">
                                                <button class="btn btn-outline-info btn-sm border-0" @onclick="() => AbrirModalEdicion(review)">
                                                    <i class="bi bi-pencil-square fs-5"></i>
                                                </button>
                                                <button class="btn btn-outline-danger btn-sm border-0" @onclick="() => EliminarReview(review.Id)">
                                                    <i class="bi bi-trash fs-5"></i>
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        }
</div>


@if (mostrarModal)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.8);" tabindex="-1">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content bg-dark text-white border-secondary shadow-lg">
                <div class="modal-header border-secondary">
                    <h5 class="modal-title small text-uppercase fw-bold">Editar entrada del diario</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CerrarModal"></button>
                </div>
                <div class="modal-body">
                    <div class="row">
                @* Poster de la película *@
                            <div class="col-md-4 text-center d-none d-md-block"> @* Se oculta en mobile para dar aire *@
                                <img src="@reviewParaEditar?.Movie?.PosterUrl" class="img-fluid rounded shadow-lg border border-secondary" style="max-height: 350px;" alt="Poster" />
                            </div>

                @* Formulario de edición *@
                        <div class="col-md-8">
                            <h3 class="fw-bold">@reviewParaEditar?.Movie?.Title</h3>
                            <p class="text-muted small">@reviewParaEditar?.Movie?.Year</p>

                            <div class="mb-3">
                                <label class="form-label small text-muted">Reseña</label>
                                <textarea @bind="reviewParaEditar.Comment" class="form-control bg-secondary text-white border-0" rows="5" placeholder="Escribe tu opinión..."></textarea>
                            </div>

                            <div class="d-flex justify-content-between align-items-center mt-3">
                                <div>
                                    <label class="d-block small text-muted mb-1">Calificación</label>
                                    <div class="text-warning fs-4">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    int starIndex = i;
                                                    <i class="bi @(starIndex <= reviewParaEditar.Stars ? "bi-star-fill" : "bi-star") pointer" 
                                                        @onclick="() => reviewParaEditar.Stars = starIndex" style="cursor:pointer;"></i>
                                }
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                    <div class="modal-footer border-secondary d-flex justify-content-between">
                            <button type="button" class="btn btn-outline-danger px-3" @onclick="() => EliminarReview(reviewParaEditar.Id)">
                                <i class="bi bi-trash"></i>
                            </button>
                            <div class="d-flex gap-2">
                                <button type="button" class="btn btn-secondary px-4" @onclick="CerrarModal">Cancelar</button>
                                <button type="button" class="btn btn-warning fw-bold px-4" @onclick="GuardarCambios">Guardar</button>
                            </div>
                    </div>
            </div>
        </div>
    </div>
}


<style>
    .main-content-container {
        background-color: #121212 !important;
        min-height: 100vh;
    }

    .comment-card {
        background-color: #1e1e1e !important;
        border-color: #333 !important;
        transition: all 0.3s ease;
    }

    .comment-card:hover {
        border-color: #ffc107 !important;
        transform: translateY(-2px);
    }

   /* Valores estándar de Bootstrap pero reforzados */
.modal {
    z-index: 3000 !important;
}

.modal-backdrop {
    z-index: 2900 !important;
}

/* Ajuste para que el modal no se pegue tanto abajo en celulares */
    @@media (max-width: 768px) {
    .modal-dialog {
        margin-bottom: 80px; /* Le damos espacio para que el menú no moleste visualmente */
    }
}

    /* Estilo para los botones en desktop */
    .btn-outline-info:hover { background-color: #0dcaf0; color: black; }
    .btn-outline-danger:hover { background-color: #dc3545; color: white; }
</style>


@code {
    private List<Review>? userReviews;
    private Review? reviewParaEditar;
    private bool mostrarModal = false;

    protected override async Task OnInitializedAsync()
    {
        await CargarReviews();
    }

    private async Task CargarReviews()
    {
        userReviews = await Http.GetFromJsonAsync<List<Review>>("api/reviews/user");
    }

    private void AbrirModalEdicion(Review review)
    {
        // Creamos una copia para no modificar la lista original antes de guardar
        reviewParaEditar = new Review
            {
                Id = review.Id,
                Comment = review.Comment,
                Stars = review.Stars,
                MovieId = review.MovieId,
                Movie = review.Movie,
                UserId = review.UserId
            };
        mostrarModal = true;
    }

    private void CerrarModal() => mostrarModal = false;

    private async Task GuardarCambios()
    {
        if (reviewParaEditar == null) return;

        var response = await Http.PutAsJsonAsync($"api/reviews/{reviewParaEditar.Id}", reviewParaEditar);

        if (response.IsSuccessStatusCode)
        {
            await CargarReviews(); // Recarga la tabla
            CerrarModal();
        }
    }

    private async Task EliminarReview(int id)
    {
        // Aquí podrías cerrar el modal antes si venís desde el botón "Eliminar" del modal
        var response = await Http.DeleteAsync($"api/reviews/{id}");
        if (response.IsSuccessStatusCode)
        {
            await CargarReviews();
            CerrarModal();
        }
    }
}