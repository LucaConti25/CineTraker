@page "/mis-peliculas"
@using CineTraker.Shared
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@inject HttpClient Http
@inject NavigationManager Nav

<div class="container mt-4">
    <h2 class="text-white mb-4"><i class="bi bi-journal-bookmark-fill me-2"></i>Mi Diario de Películas</h2>

    @if (userReviews == null)
    {
            <div class="text-center text-white">
                <div class="spinner-border text-primary" role="status"></div>
                <p class="mt-2">Cargando tus reseñas...</p>
            </div>
    }
    else if (!userReviews.Any())
    {
            <div class="alert alert-info bg-dark text-info border-info">
                Todavía no has calificado ninguna película. ¡Empieza explorando la cartelera!
            </div>
    }
    else
    {
            <div class="table-responsive">
                <table class="table table-dark table-hover align-middle">
                    <thead>
                        <tr class="text-muted small text-uppercase">
                            <th>Película</th>
                            <th>Fecha</th>
                            <th>Calificación</th>
                            <th>Comentario</th>
                            <th class="text-end">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var review in userReviews)
                    {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center">
                                    @* Asumiendo que tenés la propiedad Movie en el modelo Review *@
                                            <strong class="text-white">@review.Movie?.Title</strong>
                                        </div>
                                    </td>
                                    <td class="text-muted small">@review.CreatedAt.ToString("dd MMM yyyy")</td>
                                    <td>
                                        <span class="text-warning">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                                    <i class="bi @(i <= review.Stars ? "bi-star-fill" : "bi-star")"></i>
                                    }
                                        </span>
                                    </td>
                                    <td class="text-truncate" style="max-width: 300px;">
                                        <span class="text-light small">@review.Comment</span>
                                    </td>
                                    <td class="text-end">
                                        <button class="btn btn-outline-info btn-sm me-2" @onclick="() => AbrirModalEdicion(review)">
                                            <i class="bi bi-pencil-square"></i>
                                        </button>
                                        <button class="btn btn-outline-danger btn-sm" @onclick="() => EliminarReview(review.Id)">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                    }
                    </tbody>
                </table>
            </div>
    }
</div>

@if (mostrarModal)
{
        <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.8);" tabindex="-1">
            <div class="modal-dialog modal-lg modal-dialog-centered">
                <div class="modal-content bg-dark text-white border-secondary shadow-lg">
                    <div class="modal-header border-secondary">
                        <h5 class="modal-title small text-uppercase fw-bold">Editar entrada del diario</h5>
                        <button type="button" class="btn-close btn-close-white" @onclick="CerrarModal"></button>
                    </div>
                    <div class="modal-body">
                        <div class="row">
                        @* Poster de la película *@
                            <div class="col-md-4 text-center">
                                <img src="@reviewParaEditar?.Movie?.PosterUrl" class="img-fluid rounded shadow" style="max-height: 300px;" alt="Poster" />
                            </div>

                        @* Formulario de edición *@
                            <div class="col-md-8">
                                <h3 class="fw-bold">@reviewParaEditar?.Movie?.Title</h3>
                                <p class="text-muted small">@reviewParaEditar?.Movie?.Year</p>

                                <div class="mb-3">
                                    <label class="form-label small text-muted">Reseña</label>
                                    <textarea @bind="reviewParaEditar.Comment" class="form-control bg-secondary text-white border-0" rows="5" placeholder="Escribe tu opinión..."></textarea>
                                </div>

                                <div class="d-flex justify-content-between align-items-center mt-3">
                                    <div>
                                        <label class="d-block small text-muted mb-1">Calificación</label>
                                        <div class="text-warning fs-4">
                                        @for (int i = 1; i <= 5; i++)
                                        {
                                            int starIndex = i;
                                                    <i class="bi @(starIndex <= reviewParaEditar.Stars ? "bi-star-fill" : "bi-star") pointer" 
                                                       @onclick="() => reviewParaEditar.Stars = starIndex" style="cursor:pointer;"></i>
                                        }
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer border-secondary justify-content-between">
                        <button type="button" class="btn btn-outline-danger" @onclick="() => EliminarReview(reviewParaEditar.Id)">Eliminar</button>
                        <div>
                            <button type="button" class="btn btn-secondary me-2" @onclick="CerrarModal">Cancelar</button>
                            <button type="button" class="btn btn-success px-4" @onclick="GuardarCambios">Guardar</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
}

@code {
    private List<Review>? userReviews;
    private Review? reviewParaEditar;
    private bool mostrarModal = false;

    protected override async Task OnInitializedAsync()
    {
        await CargarReviews();
    }

    private async Task CargarReviews()
    {
        userReviews = await Http.GetFromJsonAsync<List<Review>>("api/reviews/user");
    }

    private void AbrirModalEdicion(Review review)
    {
        // Creamos una copia para no modificar la lista original antes de guardar
        reviewParaEditar = new Review
            {
                Id = review.Id,
                Comment = review.Comment,
                Stars = review.Stars,
                MovieId = review.MovieId,
                Movie = review.Movie,
                UserId = review.UserId
            };
        mostrarModal = true;
    }

    private void CerrarModal() => mostrarModal = false;

    private async Task GuardarCambios()
    {
        if (reviewParaEditar == null) return;

        var response = await Http.PutAsJsonAsync($"api/reviews/{reviewParaEditar.Id}", reviewParaEditar);

        if (response.IsSuccessStatusCode)
        {
            await CargarReviews(); // Recarga la tabla
            CerrarModal();
        }
    }

    private async Task EliminarReview(int id)
    {
        // Aquí podrías cerrar el modal antes si venís desde el botón "Eliminar" del modal
        var response = await Http.DeleteAsync($"api/reviews/{id}");
        if (response.IsSuccessStatusCode)
        {
            await CargarReviews();
            CerrarModal();
        }
    }
}