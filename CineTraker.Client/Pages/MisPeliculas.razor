@code {
    private List<Movie> peliculas = new List<Movie>();
    private string textoBusqueda = "";
    private bool buscandoEnApi = false;
    private List<FiltroDecada> filtrosDecadas = new();

    private bool mostrarDropdown = false; 
    private bool mostrarGenero = false;
    private bool mostrarRating = false;
    private bool mostrarPlataforma = false;

    private int skipActual = 0;        // Cuántas ya cargamos
    private const int takeTanda = 20;   // Cuántas pedimos por vez
    private bool cargandoMas = false;   // Para no pedir 2 veces lo mismo mientras carga
    private bool finDelCatalogo = false; // Para saber si ya no hay más pelis

    private void ToggleDropdown() => mostrarDropdown = !mostrarDropdown;
    private void ToggleGenero() => mostrarGenero = !mostrarGenero;
    private void ToggleRating() => mostrarRating = !mostrarRating;


    private List<Movie> resultadosExternos = new(); // Para guardar lo que traiga la API
    private bool mostrarModalExterno = false;       // Para controlar si el modal se ve o no
    private bool mostrarFeedback = false;
    private string peliculaAgregada = "";
    private string? generoSeleccionado = null;
    private string? plataformaSeleccionada = null;
    private double? ratingSeleccionado = null;
    private List<string> generos = new() { "Action", "Drama", "Comedy", "Thriller", "Horror", "Sci-Fi" };


    private List<string> plataformasFrecuentes = new() { "Netflix", "MAX", "Disney+", "Prime Video", "AppleTV", "MUBI", "Clarovideo", "Paramount Plus" };

    private void TogglePlataforma() => mostrarPlataforma = !mostrarPlataforma;

    private async Task CerrarPlataforma()
    {
        await Task.Delay(200); // Delay para que tome el click antes de cerrar
        mostrarPlataforma = false;
        StateHasChanged();
    }

    private async Task SeleccionarPlataforma(string? p)
    {
        plataformaSeleccionada = p;
        mostrarPlataforma = false;
        await CargarCatalogo(true); // Esto dispara la query con el JOIN en el backend
    }

    private List<Movie> PeliculasFiltradas
    {
        get
        {
            var query = peliculas ?? new List<Movie>();

            // Filtro 1: Texto (Búsqueda en el cliente)
            if (!string.IsNullOrWhiteSpace(textoBusqueda))
                query = query.Where(p => p.Title.Contains(textoBusqueda, StringComparison.OrdinalIgnoreCase)).ToList();

            // Filtro 2: Década (Lógica de rangos)
            var seleccionado = filtrosDecadas.FirstOrDefault(f => f.Seleccionado);
            if (seleccionado != null)
                query = query.Where(p => p.Year >= seleccionado.AnioInicio && p.Year <= seleccionado.AnioInicio + 9).ToList();

            if (!string.IsNullOrEmpty(plataformaSeleccionada))
            {
                query = query.Where(p => p.Sources != null &&
                             p.Sources.Any(s => s.Name.Contains(plataformaSeleccionada))).ToList();
            }
            // Mantenemos el orden por rating también en el filtrado de memoria
            return query.OrderByDescending(p =>
            {
                double.TryParse(p.ImdbRating, System.Globalization.NumberStyles.Any, System.Globalization.CultureInfo.InvariantCulture, out var r);
                return r;
            }).ToList();
        }
    }




    private async Task CerrarDropdown()
    {
        // El delay es para que el sistema llegue a registrar el clic en la década
        // antes de que el menú desaparezca de la pantalla.
        await Task.Delay(200);
        mostrarDropdown = false;
        StateHasChanged();
    }

    private async Task CerrarGenero()
    {
        await Task.Delay(200);
        mostrarGenero = false;
        StateHasChanged();
    }

    private async Task CerrarRating()
    {
        await Task.Delay(200);
        mostrarRating = false;
        StateHasChanged();
    }



    protected override async Task OnInitializedAsync()
    {
        for (int anio = 1930; anio <= 2020; anio += 10)
        {
            filtrosDecadas.Add(new FiltroDecada(anio));
        }

        var dotNetHelper = DotNetObjectReference.Create(this);
        await JS.InvokeVoidAsync("inicializarScrollInfinito", dotNetHelper);
        await CargarCatalogo(true);
    }


    [JSInvokable]
    public async Task CargarSiguientePagina()
    {
        // Si ya estamos cargando o si ya no hay más películas, no hacemos nada
        if (cargandoMas || finDelCatalogo) return;

        cargandoMas = true;
        skipActual += takeTanda; // Aumentamos el contador (ej. de 0 a 20)

        // Llamamos a la API pidiendo la siguiente tanda
        var url = $"api/Movies?skip={skipActual}&take={takeTanda}";

        // Mantenemos los filtros activos si existen
        if (!string.IsNullOrEmpty(generoSeleccionado)) url += $"&genre={generoSeleccionado}";
        if (ratingSeleccionado.HasValue) url += $"&minRating={ratingSeleccionado.Value.ToString(System.Globalization.CultureInfo.InvariantCulture)}";
        if (!string.IsNullOrEmpty(plataformaSeleccionada)) url += $"&platform={Uri.EscapeDataString(plataformaSeleccionada)}";

        var nuevasPelis = await Http.GetFromJsonAsync<List<Movie>>(url);

        if (nuevasPelis != null && nuevasPelis.Any())
        {
            // LA CLAVE: Agregamos las nuevas a la lista existente en lugar de borrar todo
            peliculas?.AddRange(nuevasPelis);
        }
        else
        {
            // Si la API no devolvió nada, es porque llegamos al final del catálogo
            finDelCatalogo = true;
        }

        cargandoMas = false;
        StateHasChanged(); // Refrescamos la UI para que se vean los nuevos pósters
    }

    private void SeleccionarDecada(FiltroDecada filtro)
    {
        if (filtro.Seleccionado)
        {
            filtro.Seleccionado = false;
        }
        else
        {
            // Apagamos todas las demás para que solo una esté activa
            filtrosDecadas.ForEach(f => f.Seleccionado = false);
            filtro.Seleccionado = true;
        }

        mostrarDropdown = false;
        StateHasChanged();
    }





    private void LimpiarTodosLosFiltros()
    {
        filtrosDecadas.ForEach(f => f.Seleccionado = false);
        textoBusqueda = "";
        StateHasChanged();
    }





    private async Task CargarCatalogo(bool esNuevaBusqueda = false)
    {
        if (esNuevaBusqueda)
        {
            skipActual = 0;
            finDelCatalogo = false;
            peliculas = new List<Movie>();
        }

        try
        {
            var queryParams = new List<string>();

            // --- NUEVO: Agregamos la paginación a la URL ---
            queryParams.Add($"skip={skipActual}");
            queryParams.Add($"take={takeTanda}");

            if (!string.IsNullOrEmpty(generoSeleccionado))
                queryParams.Add($"genre={generoSeleccionado}");

            if (ratingSeleccionado.HasValue && ratingSeleccionado > 0)
                queryParams.Add($"minRating={ratingSeleccionado.Value.ToString(System.Globalization.CultureInfo.InvariantCulture)}");

            if (!string.IsNullOrEmpty(plataformaSeleccionada))
            {
                var plataformaCodificada = Uri.EscapeDataString(plataformaSeleccionada);
                queryParams.Add($"platform={plataformaCodificada}");
            }

            var url = "api/Movies?" + string.Join("&", queryParams);

            var resultado = await Http.GetFromJsonAsync<List<Movie>>(url);

            if (resultado != null)
            {
                if (esNuevaBusqueda || peliculas == null)
                {
                    peliculas = resultado;
                }
                else
                {
                    // Si no es nueva búsqueda, las sumamos a las que ya están
                    peliculas.AddRange(resultado);
                }

                // Si trajo menos de los que pedimos, llegamos al final
                if (resultado.Count < takeTanda)
                {
                    finDelCatalogo = true;
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al cargar: {ex.Message}");
        }
    }





    private async Task EjecutarBusquedaInteligente()
    {
        if (string.IsNullOrWhiteSpace(textoBusqueda)) return;

        buscandoEnApi = true;
        mostrarModalExterno = true; // Abrimos el modal con el spinner mientras la API responde.

        try
        {
            // Pedimos la lista de candidatos para que el usuario elija la correcta.
            var resultados = await Http.GetFromJsonAsync<List<Movie>>($"api/Movies/smart-search/{textoBusqueda}");

            if (resultados != null)
            {
                resultadosExternos = resultados;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error en SmartSearch: {ex.Message}");
            mostrarModalExterno = false; // Si falla, cerramos el modal
        }
        finally
        {
            buscandoEnApi = false;
            StateHasChanged(); // Forzamos el refresco para que se vea el modal con la data
        }
    }





    private async Task ConfirmarYGuardar(Movie peli)
    {
        // El usuario ya eligió, ahora sí impactamos la base de datos local.
        var response = await Http.PostAsJsonAsync("api/Movies/save-by-id", peli.ImdbID);

        if (response.IsSuccessStatusCode)
        {
            peliculaAgregada = peli.Title;
            mostrarModalExterno = false;
            mostrarFeedback = true;

            StateHasChanged();

            await Task.Delay(2500);

            mostrarFeedback = false;
            textoBusqueda = "";
            await CargarCatalogo(true);
        }
        else
        {
            // Leemos el mensaje de error del backend (por ejemplo, si ya existe)
            var errorMsg = await response.Content.ReadAsStringAsync();
            Console.WriteLine($"Error al guardar: {errorMsg}");
        }

    }

    private async Task SeleccionarGenero(string? g)
    {
        generoSeleccionado = g;
        mostrarGenero = false;
        await CargarCatalogo(true);
    }

    private async Task SeleccionarRating(double? r)
    {
        ratingSeleccionado = r;
        mostrarRating = false;
        await CargarCatalogo(true);
    }
