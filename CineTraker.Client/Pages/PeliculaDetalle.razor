@page "/pelicula/{Id:int}"
@using CineTraker.Shared
@inject HttpClient Http
@inject NavigationManager Navigation

<div class="container py-5">
    @if (pelicula == null)
    {
            <div class="text-center mt-5">
                <div class="spinner-border text-danger" role="status"></div>
                <p class="text-muted mt-2">Cargando detalles de la película...</p>
            </div>
    }
    else
    {
            <button class="btn btn-outline-secondary mb-4" @onclick='() => Navigation.NavigateTo("/")'>
                <i class="bi bi-arrow-left"></i> Volver al catálogo
            </button>

            <div class="row">

                <div class="col-md-4 mb-4">
                    <img src="@pelicula.PosterUrl" class="img-fluid rounded shadow-lg w-100" alt="@pelicula.Title" />

                @* esto es lo de streaming, no funciona todavia*@
                    <div class="mt-4 p-3 rounded" style="background-color: #1a1a1a; border: 1px solid #333;">
                        <p class="text-uppercase fw-bold mb-2" style="color: #888; font-size: 0.85rem; letter-spacing: 1px;">
                            Disponible en:
                        </p>
                        <div class="d-flex flex-wrap gap-2">
                            @if (pelicula.Sources != null && pelicula.Sources.Any())
                            {
                                @foreach (var source in pelicula.Sources)
                                {
                                    <a href="@source.WebUrl" target="_blank" class="streaming-btn">
                                        @source.Name
                                    </a>
                                }
                            }
                            else
                            {
                                <span class="text-muted small">No disponible en suscripción (AR)</span>
                            }
                        </div>
                    </div>
                </div>


                <div class="col-md-8 text-light">
                    <h1 class="display-4 fw-bold">@pelicula.Title</h1>
                    <p class="lead text-muted">@pelicula.Year | Dirigida por @pelicula.Director</p>

                    <hr class="border-secondary" />

                    <h5 class="fw-bold text-info">Sinopsis</h5>
                    <p style="font-size: 1.1rem; line-height: 1.6;">@pelicula.Plot</p>

                
                    <div class="mt-5 p-4 rounded shadow-sm" style="background-color: #1e1e1e; border: 1px solid #333;">
                        <h4 class="text-light mb-3">⭐ Dejá tu puntuación</h4>

                        <div class="mb-3 d-flex gap-2">
                        @for (int i = 1; i <= 5; i++)
                        {
                            int starIndex = i;
                                    <i class="bi @(starIndex <= puntajeSeleccionado ? "bi-star-fill text-warning" : "bi-star text-secondary")" 
                                       style="cursor: pointer; font-size: 2rem;" 
                                       @onclick="() => SeleccionarPuntaje(starIndex)"></i>
                        }
                        </div>

                        <textarea class="form-control bg-dark text-light border-secondary mb-3 shadow-none" 
                                  rows="3" placeholder="Escribí una breve reseña..." 
                                  @bind="comentarioUsuario"></textarea>

                        <button class="btn btn-warning fw-bold px-4 shadow" @onclick="GuardarReview" disabled="@estaGuardando">
                        @if (estaGuardando)
                        {
                                    <span class="spinner-border spinner-border-sm me-2"></span>
                        } 
                            Guardar Review
                        </button>
                    </div>
                </div> 
            </div> 

        
            <div class="mt-5 pt-4 border-top border-secondary">
                <h3 class="text-light mb-4">Comentarios de CineTrakers</h3>

            @if (reviewsExistentes == null || !reviewsExistentes.Any())
            {
                        <div class="p-4 rounded bg-dark text-center text-muted border border-secondary border-dashed">
                            <i class="bi bi-chat-dots d-block mb-2" style="font-size: 2rem;"></i>
                            Nadie comentó todavía sobre "@pelicula.Title". ¡Sé el primero!
                        </div>
            }
            else
            {
                        <div class="row row-cols-1 g-3">
                    @foreach (var rev in reviewsExistentes)
                    {
                                    <div class="col">
                                        <div class="card bg-dark border-secondary shadow-sm">
                                            <div class="card-body">
                                                <div class="d-flex justify-content-between align-items-start">
                                                    <div class="text-warning mb-2">
                                            @for (int i = 1; i <= 5; i++)
                                            {
                                                                <i class="bi @(i <= rev.Stars ? "bi-star-fill" : "bi-star text-secondary")"></i>
                                            }
                                                    </div>
                                                    <span class="text-muted small">#@rev.Id</span>
                                                </div>
                                                <p class="text-light mb-0" style="white-space: pre-wrap;">@rev.Comment</p>
                                            </div>
                                        </div>
                                    </div>
                    }
                        </div>
            }
            </div>
    }
</div>

<style>
    .streaming-box {
        background-color: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 12px;
        padding: 1.5rem;
        margin-top: 2rem;
    }

    .streaming-title {
        color: #888;
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        margin-bottom: 1rem;
    }

    /* Botones de las plataformas */
    .streaming-btn {
        display: inline-block;
        background-color: transparent;
        color: #00adff;
        border: 1px solid #00adff;
        padding: 8px 20px;
        border-radius: 50px; /* Estilo 'píldora' */
        text-decoration: none;
        font-size: 0.85rem;
        font-weight: 600;
        transition: all 0.25s ease-in-out;
    }

        .streaming-btn:hover {
            background-color: #00adff;
            color: #fff;
            transform: translateY(-3px);
            box-shadow: 0 5px 15px rgba(0, 173, 255, 0.4);
        }

    /* Texto cuando no hay nada */
    .no-sources {
        font-style: italic;
        color: #666;
        font-size: 0.9rem;
    }
</style>

@code {
    [Parameter] public int Id { get; set; }
    private Movie? pelicula;
    private List<Review> reviewsExistentes = new(); 
    private int puntajeSeleccionado = 0;
    private string comentarioUsuario = "";
    private bool estaGuardando = false;

    protected override async Task OnInitializedAsync()
    {
        await CargarDatos();
    }

    private async Task CargarDatos()
    {
        try
        {
            pelicula = await Http.GetFromJsonAsync<Movie>($"api/Movies/{Id}");
            reviewsExistentes = await Http.GetFromJsonAsync<List<Review>>($"api/Reviews/movie/{Id}");
        }
        catch (Exception ex) { Console.WriteLine($"Error: {ex.Message}"); }
    }

    private void SeleccionarPuntaje(int stars) => puntajeSeleccionado = stars;

    private async Task GuardarReview()
    {
        if (puntajeSeleccionado == 0) return;
        estaGuardando = true;

        var nueva = new Review
            {
                MovieId = Id,
                Stars = puntajeSeleccionado,
                Comment = comentarioUsuario
            };

        var res = await Http.PostAsJsonAsync("api/Reviews", nueva);
        if (res.IsSuccessStatusCode)
        {
            comentarioUsuario = "";
            puntajeSeleccionado = 0;
            await CargarDatos(); 
        }
        estaGuardando = false;
    }
}
