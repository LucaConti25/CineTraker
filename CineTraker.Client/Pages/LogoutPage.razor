@page "/logout" 
@using CineTraker.Client.Services
@inject AuthService AuthService
@inject NavigationManager Navigation

@if (mostrarFeedback)
{
    <div class="feedback-toast shadow-lg border-0 animacion-entrada">
        <div class="d-flex align-items-center p-3 text-white bg-danger rounded">
            <i class="bi bi-box-arrow-right me-2 fs-4"></i>
            <div>
                <strong class="d-block">¡Sesión cerrada!</strong>
                <span class="small">Hasta la próxima.</span>
            </div>
        </div>
    </div>
}

<style>
    .feedback-toast {
        position: fixed;
        bottom: 30px;
        right: 30px;
        z-index: 10000;
        min-width: 250px;
    }

    .animacion-entrada {
        animation: slideInRight 0.5s ease-out;
    }

    @@keyframes slideInRight {
        from {
            transform: translateX(100%);
            opacity: 0;
        }

        to {
            transform: translateX(0);
            opacity: 1;
        }
    }
</style>

@code {
    private bool mostrarFeedback = false;

    protected override async Task OnInitializedAsync()
    {
        // 1. Ejecutamos el logout apenas entra
        await AuthService.Logout();
        mostrarFeedback = true;
        StateHasChanged();
        await Task.Delay(1500);

        Navigation.NavigateTo("/", forceLoad: true);
    }
}